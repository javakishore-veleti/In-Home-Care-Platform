  <diagram name="6. LangGraph Agentic Flows" id="ihcp-6">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="LangGraph Agentic Flows — three workflows" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="f1" value="slack_channel_responder_flow&#10;Watches #field-ops, #customer-support, #care-admin&#10;Classifier → Retriever (VectorDB) → Answerer (LLM) → Responder (Slack reply)&#10;Escalation branch when no grounded answer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1080" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="f2" value="visit_intelligence_flow&#10;Triggered on visit completion (status=COMPLETED event from Kafka)&#10;Scorer → Gap Detector → Disposition Writer&#10;Uses VectorDB for similar past visits + MCP tools for member/visit lookup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="1080" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="document_author_flow&#10;Triggered after document_intelligence_svc processes a new visit document&#10;Summarizer → Reviewer Prompt → Draft Writer&#10;Draft presented for staff review in care_admin_portal or Slack" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="1080" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="shared" value="Shared infra: VectorClient Protocol (Qdrant default) · LlmClient Protocol (Google ADK default) · MCP tools via mcp_gateway · MongoDB for state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1080" height="60" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
