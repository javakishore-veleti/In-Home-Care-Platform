        <mxCell id="c7" value="messages (slack_responder)&#10;---&#10;_id, event_id, channel&#10;agent_id, text, ts, thread_ts" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=Courier New;fontSize=11" vertex="1" parent="1"><mxGeometry x="580" y="300" width="240" height="140" as="geometry"/></mxCell>
