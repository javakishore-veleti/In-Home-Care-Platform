        <mxCell id="c5" value="visit_documents (visit_ingest_svc)&#10;---&#10;_id, visit_id, member_id&#10;doc_type, raw_text&#10;ocr_confidence" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=Courier New;fontSize=11" vertex="1" parent="1"><mxGeometry x="40" y="300" width="260" height="140" as="geometry"/></mxCell>
