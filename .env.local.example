# In-Home-Care-Platform local-dev environment.
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Anything you put in .env.local is auto-sourced by:
#   - npm run local:middleware:start-all
#   - bash DevOps/Local/member-middleware-start.sh
#   - bash DevOps/Local/slack-tunnel.sh up
#
# So you only have to export these once. Restart middleware after edits.
#
# ----- Slack -----------------------------------------------------------
# Bot user OAuth token (xoxb-...). Required for slack_svc to post.
SLACK_BOT_TOKEN=xoxb-replace-me
#
# Signing secret from the Slack app's "Basic Information → App Credentials"
# page. Required for slack_svc to verify inbound interactivity / events
# webhook calls.
SLACK_SIGNING_SECRET=replace-me-32-char-hex
#
# (Optional) Pin a static ngrok subdomain so the URL never changes:
# NGROK_DOMAIN=your-name.ngrok-free.app
# Get one free at: https://dashboard.ngrok.com/cloud-edge/domains
#
# (Optional) Auto-push the public tunnel URL into Slack's app manifest
# every time `npm run local:slack:tunnel:up` runs. Without these, the
# tunnel script just prints the URL and you paste it into the Slack
# app admin pages by hand.
#
# Get the App Configuration Token from
#   https://api.slack.com/apps -> Manage Distribution -> App Configuration Tokens
# (one-time per workspace; click "Generate Token" for your workspace).
SLACK_APP_ID=A0AS...
SLACK_APP_CONFIG_TOKEN=xoxe.xoxp-...
#
# ----- Kafka -----------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
#
# ----- Database --------------------------------------------------------
DATABASE_URL=postgresql://care:care@localhost:5432/in_home_care_platform
#
# ----- JWT (auth_svc) --------------------------------------------------
# Override the default `in-home-care-local-secret` if you want JWTs
# issued from this machine to not be valid on someone else's checkout.
# IHCP_JWT_SECRET=change-me
#
# ----- LLM (knowledge_agent_svc) ----------------------------------------
# The briefing agent uses the OpenAI-compatible chat completions API.
# Pick ONE provider by uncommenting its block. Default: Ollama (free, local).
#
# --- Ollama (free, local, default) ---
LLM_API_BASE=http://localhost:11434/v1
LLM_MODEL=llama3
# LLM_API_KEY=            (not needed for Ollama)
#
# --- OpenAI ---
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
#
# --- Anthropic Claude (via OpenAI-compatible proxy or direct) ---
# LLM_API_BASE=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...
# Note: Claude's native API uses a different format. For Phase 3a,
# use an OpenAI-compatible proxy like LiteLLM, or wait for Phase 3b
# which adds a native Anthropic adapter.
#
# --- Google Gemini ---
# LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=AIza...
#
# --- GitHub Copilot / Azure OpenAI ---
# LLM_API_BASE=https://models.inference.ai.azure.com
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=ghp_...     (GitHub PAT with Copilot access)
#
# Common settings (all providers):
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
